{
  "id": null,
  "uid": "bachatsetu-overview",
  "title": "BachatSetu — Production Overview",
  "description": "Starter dashboard provisioned by Sprint 9.1. See docs/deployment/monitoring-guide.md for the metrics reference and how to extend this dashboard.",
  "tags": ["bachatsetu", "backend"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests/sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"bachatsetu-backend\"}[1m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error % (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{job=\"bachatsetu-backend\", outcome=\"SERVER_ERROR\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"bachatsetu-backend\"}[5m]))",
          "legendFormat": "error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Average response time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{job=\"bachatsetu-backend\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"bachatsetu-backend\"}[5m]))",
          "legendFormat": "avg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "p95 response time",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"bachatsetu-backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "p99 response time",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"bachatsetu-backend\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM Heap",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"bachatsetu-backend\", area=\"heap\"})",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"bachatsetu-backend\", area=\"heap\"})",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM Non-Heap",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"bachatsetu-backend\", area=\"nonheap\"})",
          "legendFormat": "used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "GC pause time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum{job=\"bachatsetu-backend\"}[5m])) by (action)",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Thread count",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_threads_live_threads{job=\"bachatsetu-backend\"})",
          "legendFormat": "live threads",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Database connections (HikariCP)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(hikaricp_connections_active{job=\"bachatsetu-backend\"})",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "sum(hikaricp_connections_idle{job=\"bachatsetu-backend\"})",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "sum(hikaricp_connections_max{job=\"bachatsetu-backend\"})",
          "legendFormat": "max",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "title": "Redis (Lettuce) command latency",
      "type": "timeseries",
      "description": "Average completion latency across all Redis commands issued by the backend, via Lettuce's Micrometer command-latency recorder (RedisMetricsConfig). There is no separate Redis-server exporter yet — see the monitoring guide's Known limitations.",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(lettuce_command_completion_seconds_sum{job=\"bachatsetu-backend\"}[5m])) / sum(rate(lettuce_command_completion_seconds_count{job=\"bachatsetu-backend\"}[5m]))",
          "legendFormat": "avg command latency",
          "refId": "A"
        }
      ]
    }
  ]
}

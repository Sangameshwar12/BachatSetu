<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
        <Class name="~.*MapperImpl"/>
    </Match>
    <Match>
        <Class name="~.*\.integration\..*"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <!-- EntityManager is a container-managed collaborator injected by reference. -->
        <Class name="in.bachatsetu.backend.infrastructure.persistence.adapter.EntityManagerJpaReferenceProvider"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <!-- Bidirectional JPA associations intentionally retain and expose managed entity references. -->
        <Or>
            <Class name="in.bachatsetu.backend.infrastructure.persistence.entity.community.AuctionBidJpaEntity"/>
            <Class name="in.bachatsetu.backend.infrastructure.persistence.entity.community.DrawJpaEntity"/>
            <Class name="in.bachatsetu.backend.infrastructure.persistence.entity.community.InstallmentJpaEntity"/>
            <Class name="in.bachatsetu.backend.infrastructure.persistence.entity.community.MembershipHistoryJpaEntity"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <!-- Aggregate constructors enforce invariants; domain aggregates do not implement finalizers. -->
        <Class name="in.bachatsetu.backend.shared.domain.BaseAggregateRoot"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
</FindBugsFilter>

<?xml version="1.0"?>
<ruleset name="BachatSetu PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
    <description>High-signal defect and resource-safety rules for BachatSetu.</description>

    <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>
    <rule ref="category/java/bestpractices.xml/UnusedPrivateMethod"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryImport"/>
    <rule ref="category/java/errorprone.xml/BrokenNullCheck"/>
    <rule ref="category/java/errorprone.xml/CloseResource"/>
    <rule ref="category/java/errorprone.xml/EmptyCatchBlock">
        <properties>
            <!-- Best-effort audit recording (see docs/application/audit.md) intentionally swallows a
                 caught exception with only an explanatory comment: application-layer code may not use a
                 logging framework (see LayerDependencyArchitectureTest), so a comment is the only allowed
                 explanation. -->
            <property name="allowCommentedBlocks" value="true"/>
        </properties>
    </rule>
    <rule ref="category/java/errorprone.xml/ReturnFromFinallyBlock"/>
</ruleset>

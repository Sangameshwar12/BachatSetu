# Copy to `.env` next to docker-compose.prod.yml and fill in every value before running
# `docker compose -f docker-compose.prod.yml up -d --build`. Every variable without a
# comment marking it optional is required — the compose file fails fast (via
# `${VAR:?message}`) rather than silently falling back to a development default.
#
# See docs/deployment/environment-variables-guide.md for what each value means, how it
# is used, and where to source it from in a real deployment (e.g. AWS Secrets Manager).

# --- Database -----------------------------------------------------------------
DATABASE_NAME=bachatsetu
DATABASE_USERNAME=bachatsetu
DATABASE_PASSWORD=
DATABASE_MAX_POOL_SIZE=30

# --- Redis ----------------------------------------------------------------------
REDIS_PASSWORD=

# --- Auth / JWT -------------------------------------------------------------------
# Generate with: openssl rand -base64 64
AUTH_JWT_SIGNING_SECRET=
# Comma-separated list of exact browser origins allowed to call the API.
AUTH_CORS_ALLOWED_ORIGINS=https://app.example.com

# --- Frontend ---------------------------------------------------------------------
# Must be the public HTTPS URL the browser can reach the backend at (through the load
# balancer / Nginx), not an internal container hostname.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# --- SMS provider (required for OTP delivery — signup/login cannot work without one) ---
# Selects the active provider: MSG91, FAST2SMS, or TWILIO. Only that provider's own
# variables below need to be filled in.
SMS_PROVIDER=MSG91
SMS_RETRY_COUNT=2
SMS_CONNECT_TIMEOUT=3s
SMS_READ_TIMEOUT=5s
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
FAST2SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email provider (required — welcome/signup/invitation emails cannot send without one) -
# Selects the active provider: AWS_SES, RESEND, or SENDGRID. Only that provider's own
# variables below need to be filled in.
EMAIL_PROVIDER=AWS_SES
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=
EMAIL_RETRY_COUNT=2
EMAIL_CONNECT_TIMEOUT=3s
EMAIL_READ_TIMEOUT=5s
AWS_SES_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
RESEND_API_KEY=
SENDGRID_API_KEY=

# --- Payment gateways (optional — leave blank until a provider is enabled) --------
# Selects which provider's credentials below are active: RAZORPAY, STRIPE, or CASHFREE.
PAYMENT_GATEWAY_DEFAULT_PROVIDER=RAZORPAY
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_WEBHOOK_SECRET=

# --- Storage (optional — defaults to LOCAL, not suitable for multi-instance prod) -
# LOCAL is currently the only fully-implemented provider (AWS/Azure/GCP adapters are
# simulated pending real SDK integration). LOCAL files persist to the backend-prod-storage
# Docker volume, so they survive redeploys but do NOT survive scaling the backend beyond
# one instance — provision real object storage before doing so.
STORAGE_DEFAULT_PROVIDER=LOCAL
STORAGE_LOCAL_PATH=./data/storage
STORAGE_AWS_BUCKET=
STORAGE_AWS_REGION=
STORAGE_AWS_ACCESS_KEY_ID=
STORAGE_AWS_SECRET_ACCESS_KEY=

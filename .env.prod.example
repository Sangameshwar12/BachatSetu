# Copy to `.env` next to docker-compose.prod.yml and fill in every value before running
# `docker compose -f docker-compose.prod.yml up -d --build`. Every variable without a
# comment marking it optional is required — the compose file fails fast (via
# `${VAR:?message}`) rather than silently falling back to a development default.
#
# See docs/deployment/environment-variables-guide.md for what each value means, how it
# is used, and where to source it from in a real deployment (e.g. AWS Secrets Manager).

# --- Database -----------------------------------------------------------------
DATABASE_NAME=bachatsetu
DATABASE_USERNAME=bachatsetu
DATABASE_PASSWORD=
DATABASE_MAX_POOL_SIZE=30

# --- Redis ----------------------------------------------------------------------
REDIS_PASSWORD=

# --- Tenancy / auditing ------------------------------------------------------------
# The single tenant this deployment serves — provision this id in platform.tenants before
# go-live (via the Platform Admin tenant management API) and use the exact same id here.
# Generate with: uuidgen (or any UUID v4 generator) — must not be the local development
# placeholder 00000000-0000-0000-0000-000000000000.
TENANT_DEFAULT_ID=
# Recorded as created_by/updated_by only for the handful of pre-authentication requests that
# have no signed-in user yet (signup, OTP request) — every other write uses the real actor.
# Generate with: uuidgen — must not be the local development placeholder
# 00000000-0000-0000-0000-000000000001.
AUDIT_SYSTEM_ACTOR_ID=

# --- Auth / JWT -------------------------------------------------------------------
# Generate with: openssl rand -base64 64
AUTH_JWT_SIGNING_SECRET=
# Comma-separated list of exact browser origins allowed to call the API.
AUTH_CORS_ALLOWED_ORIGINS=https://app.example.com
# TEMPORARY MVP TEST OTP — REMOVE BEFORE PRODUCTION. Leave false. Setting true makes every
# generated OTP the fixed code 102030 for every user (no real SMS/Email provider needed) — for
# MVP/demo use only, never for a real production launch.
AUTH_OTP_TEST_MODE=false

# --- Frontend ---------------------------------------------------------------------
# Must be the public HTTPS URL the browser can reach the backend at (through the load
# balancer / Nginx), not an internal container hostname.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# --- SMS provider (optional — MVP mode, the default, logs the OTP instead of sending it) ---
# SMS_PROVIDER_ENABLED=false (the default) means every OTP is written to the application log
# rather than sent — correct for an MVP with no real SMS provider yet, and does not require any
# of the variables below. Set to true, select a provider (MSG91, FAST2SMS, or TWILIO), and fill
# in that provider's own variables to send real SMS — no code change needed either way.
SMS_PROVIDER_ENABLED=false
SMS_PROVIDER=MSG91
SMS_RETRY_COUNT=2
SMS_CONNECT_TIMEOUT=3s
SMS_READ_TIMEOUT=5s
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
FAST2SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email provider (optional — MVP mode, the default, logs the email instead of sending it) -
# EMAIL_PROVIDER_ENABLED=false (the default) means every email is written to the application
# log rather than sent — correct for an MVP with no real email provider yet, and does not
# require any of the variables below. Set to true, select a provider (AWS_SES, RESEND, or
# SENDGRID), and fill in that provider's own variables to send real email — no code change
# needed either way.
EMAIL_PROVIDER_ENABLED=false
EMAIL_PROVIDER=AWS_SES
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=
EMAIL_RETRY_COUNT=2
EMAIL_CONNECT_TIMEOUT=3s
EMAIL_READ_TIMEOUT=5s
AWS_SES_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
RESEND_API_KEY=
SENDGRID_API_KEY=

# --- Payment gateway (optional — disabled for MVP; leave blank until enabled) -----
# PAYMENT_GATEWAY_ENABLED=false (the default) disables the payment-gateway REST endpoints
# entirely — correct for an MVP that has no payment gateway yet. Set to true, select a provider
# (RAZORPAY, STRIPE, or CASHFREE), and fill in that provider's own variables when ready.
PAYMENT_GATEWAY_ENABLED=false
PAYMENT_GATEWAY_DEFAULT_PROVIDER=RAZORPAY
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_WEBHOOK_SECRET=

# --- Storage (optional — defaults to LOCAL, not suitable for multi-instance prod) -
# LOCAL is currently the only fully-implemented provider (AWS/Azure/GCP adapters are
# simulated pending real SDK integration). LOCAL files persist to the backend-prod-storage
# Docker volume, so they survive redeploys but do NOT survive scaling the backend beyond
# one instance — provision real object storage before doing so.
STORAGE_DEFAULT_PROVIDER=LOCAL
STORAGE_LOCAL_PATH=./data/storage
STORAGE_AWS_BUCKET=
STORAGE_AWS_REGION=
STORAGE_AWS_ACCESS_KEY_ID=
STORAGE_AWS_SECRET_ACCESS_KEY=

# --- Monitoring (Sprint 9.1) -------------------------------------------------------
# See docs/deployment/monitoring-guide.md. Prometheus and Grafana bind only to 127.0.0.1 on the
# host (see docker-compose.prod.yml) — neither is reachable from outside the host itself, so
# these ports are safe to leave at their defaults unless they collide with something else already
# running on the host.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# Change this from the default before go-live — the Grafana UI has full read/write access to
# every dashboard and datasource. Generate with: openssl rand -base64 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# The URL you actually use to reach Grafana (e.g. through an SSH tunnel to this host) — only
# affects links Grafana generates in its own UI (e.g. alert notification links), not access
# control itself.
GRAFANA_ROOT_URL=http://localhost:3001
